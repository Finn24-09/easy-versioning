{
  "name": "easy-versioning",
  "version": "1.1.1",
  "private": true,
  "description": "Auto-bump npm package versions on PR merge using Calendar Versioning",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --license licenses.txt",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --no-error-on-unmatched-pattern",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "all": "pnpm run lint && pnpm run format:check && pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "@actions/core": "^1.11.0",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/graphql": "^8.0.0",
    "@octokit/rest": "^22.0.1",
    "js-yaml": "^4.1.0",
    "minimatch": "^10.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^9.0.0",
    "jest": "^30.4.2",
    "prettier": "^3.3.0",
    "ts-jest": "^29.2.0",
    "typescript": "^6.0.3"
  }
}
